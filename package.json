{
  "name": "nexis",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "start": "node scripts/start-local.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:a11y": "playwright test -c playwright.a11y.config.ts",
    "e2e": "playwright test",
    "build": "next build",
    "analyze": "node scripts/analyze.mjs",
    "performance:mobile": "node scripts/performance/mobile-lighthouse.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "verify:e2e": "npm run e2e",
    "ai:check-provider": "node scripts/ai/check-ai-provider.mjs",
    "audio:check-betkol": "node scripts/audio/check-betkol-contract.mjs",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset-demo": "node scripts/db/run-reset-demo.mjs",
    "db:reset-empty": "node scripts/db/run-reset-empty.mjs",
    "db:ensure-demo": "node scripts/db/ensure-demo.mjs",
    "start:railway": "node scripts/start-railway.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "12.10.0",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "prisma": "^7.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "lighthouse": "^12.8.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
